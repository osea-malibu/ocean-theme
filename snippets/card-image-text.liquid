{% comment %}
    Renders a generic image + text card. Use for custom/non-content-object tiles
    such as quiz promos, brand content, or any freeform card block.

    Accepts:
    - url: {String} Link destination (optional)
    - image: {Object} Image Liquid object (required)
    - title: {String} Heading text (optional)
    - description: {String} Body text (optional)
    - cta_label: {String} CTA link label — renders a link if url is also present (optional)
    - card_classes: {String} Tailwind CSS classes (optional)
    - image_classes: {String} Tailwind CSS classes for img element (optional)
    - image_aspect: {String} Percent-based aspect ratio (in X:X format, divide 2nd value by 1st) (optional)
    - image_wrapper_classes: {String} Tailwind CSS classes (optional)
    - title_classes: {String} Tailwind CSS classes (optional)
    - description_classes: {String} Tailwind CSS classes (optional)
    - link_classes: {String} Tailwind CSS classes (optional)
    - text_wrapper_classes: {String} Tailwind CSS classes (optional)
    - fill_image: {Boolean} Image fills card height absolutely — use when card height is set by sibling tiles. Text overlays the image. Default: false (optional)

    Usage:
    {% render 'card-image-text', image: image, title: 'Take the quiz', url: '/pages/quiz', cta_label: 'Get started' %}
{% endcomment %}

<figure class="card-image-text{% if fill_image %} relative h-full overflow-hidden{% endif %}{% if card_classes != blank %} {{ card_classes }}{% endif %}">
  {%- if fill_image -%}
    <div class="absolute inset-0{% if image_wrapper_classes != blank %} {{ image_wrapper_classes }}{% endif %}">
      <img
        srcset="{{ image | image_url: width: 400 }} 400w, {{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 1200 }} 1200w"
        src="{{ image | image_url: width: 800 }}"
        alt="{{ image.alt | escape }}"
        width="{{ image.width }}"
        height="{{ image.height }}"
        loading="lazy"
        class="w-full h-full object-cover{% unless image_classes contains 'object-' %} object-center{% endunless %}{% if image_classes != blank %} {{ image_classes }}{% endif %}"
      >
    </div>
  {%- else -%}
    {%- if url != blank -%}
      <a
        href="{{ url }}"
        class="cursor-pointer hover:opacity-80 motion-safe:transition-opacity block{% if image_aspect != blank %} w-full relative {{ image_aspect }}{% endif %}{% if image_wrapper_classes != blank %} {{ image_wrapper_classes }}{% endif %}"
        {% if cta_label != blank %}tabindex="-1" aria-hidden="true"{% endif %}
      >
    {%- else -%}
      <div class="block{% if image_aspect != blank %} w-full relative {{ image_aspect }}{% endif %}{% if image_wrapper_classes != blank %} {{ image_wrapper_classes }}{% endif %}">
    {%- endif -%}
      <img
        srcset="{{ image | image_url: width: 400 }} 400w, {{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 1200 }} 1200w"
        src="{{ image | image_url: width: 800 }}"
        alt="{{ image.alt | escape }}"
        width="{{ image.width }}"
        height="{{ image.height }}"
        loading="lazy"
        class="{{ image_classes }}{% if image_aspect != blank %} absolute inset-0 object-cover{% unless image_classes contains 'object-' %} object-center{% endunless %} min-w-full min-h-full{% endif %}"
      >
    {%- if url != blank -%}
      </a>
    {%- else -%}
      </div>
    {%- endif -%}
  {%- endif -%}

  {%- if title != blank or description != blank or cta_label != blank -%}
    <figcaption class="{% if fill_image %}relative z-10 {% endif %}{{ text_wrapper_classes }}">
      {%- if title != blank -%}
        <h2 class="{{ title_classes }}">{{ title | escape }}</h2>
      {%- endif -%}
      {%- if description != blank -%}
        <p class="{{ description_classes }}">{{ description | escape }}</p>
      {%- endif -%}
      {%- if cta_label != blank and url != blank -%}
        <a href="{{ url }}" class="{{ link_classes }}">{{ cta_label | escape }}</a>
      {%- endif -%}
    </figcaption>
  {%- endif -%}
</figure>
