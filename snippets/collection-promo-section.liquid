{%- liquid
  assign mobile_img = promo_section_image_mobile
  assign desktop_img = promo_section_image_desktop

  assign mobile_media = mobile_img.value
  assign desktop_media = desktop_img.value

  assign has_video = false
  if mobile_media and mobile_media.media_type == 'video'
    assign has_video = true
  elsif desktop_media and desktop_media.media_type == 'video'
    assign has_video = true
  endif

  assign mobile_master = mobile_img | image_url
  assign desktop_master = desktop_img | image_url

  # Full-width banner sizing hint for srcset selection
  assign promo_sizes = '100vw'

  # Pick an IMAGE media object for dimensions (avoids video/non-image edge cases)
  assign dim_media = nil
  if desktop_media and desktop_media.media_type == 'image'
    assign dim_media = desktop_media
  elsif mobile_media and mobile_media.media_type == 'image'
    assign dim_media = mobile_media
  endif

  # Use real width/height if available; otherwise compute height from aspect ratio
  assign dim_w = dim_media.width | default: 1600
  assign dim_h = dim_media.height
  if dim_h == blank or dim_h == 0
    assign dim_ar = dim_media.aspect_ratio | default: 1
    if dim_ar == 0
      assign dim_ar = 1
    endif
    assign dim_h = dim_w | divided_by: dim_ar | round
  endif
-%}

{%- if promo_section_url != blank -%}
  <a href="{{ promo_section_url }}" class="block">
{%- endif -%}

{% if has_video %}
  <div class="relative w-full overflow-hidden">
    {% if mobile_media and mobile_media.media_type == 'video' %}
      {% comment %}theme-check-disable RemoteAsset {% endcomment %}
      {{ mobile_media | video_tag:
        autoplay: true,
        loop: true,
        muted: true,
        controls: false,
        playsinline: true,
        class: 'block w-full h-auto object-cover sm:hidden'
      }}
      {% comment %}theme-check-enable RemoteAsset {% endcomment %}
    {% endif %}

    {% if desktop_media and desktop_media.media_type == 'video' %}
      {% comment %}theme-check-disable RemoteAsset {% endcomment %}
      {{ desktop_media | video_tag:
        autoplay: true,
        loop: true,
        muted: true,
        controls: false,
        playsinline: true,
        class: 'hidden sm:block w-full h-auto object-cover'
      }}
      {% comment %}theme-check-enable RemoteAsset {% endcomment %}
    {% endif %}
  </div>
{% else %}
  {% comment %}theme-check-disable RemoteAsset {% endcomment %}
  <picture class="relative z-0 block w-full">
    {%- if mobile_img != blank -%}
      <source
        media="(max-width: 639px)"
        {% if mobile_master contains '.gif' %}
          srcset="{{ mobile_master }}"
        {% else %}
          srcset="
            {% render 'imgix', src: mobile_master, w: 320 %} 320w,
            {% render 'imgix', src: mobile_master, w: 480 %} 480w,
            {% render 'imgix', src: mobile_master, w: 640 %} 640w,
            {% render 'imgix', src: mobile_master, w: 750 %} 750w
          "
        {% endif %}
      >
    {%- endif -%}

    {%- if desktop_img != blank -%}
      <source
        media="(min-width: 640px)"
        {% if desktop_master contains '.gif' %}
          srcset="{{ desktop_master }}"
        {% else %}
          srcset="
            {% render 'imgix', src: desktop_master, w: 640 %} 640w,
            {% render 'imgix', src: desktop_master, w: 960 %} 960w,
            {% render 'imgix', src: desktop_master, w: 1200 %} 1200w,
            {% render 'imgix', src: desktop_master, w: 1600 %} 1600w,
            {% render 'imgix', src: desktop_master, w: 2000 %} 2000w,
            {% render 'imgix', src: desktop_master, w: 2400 %} 2400w,
            {% render 'imgix', src: desktop_master, w: 2800 %} 2800w
          "
        {% endif %}
      >
    {%- endif -%}

    <img
      {% if mobile_img != blank %}
        src="{% render 'imgix', src: mobile_master, w: 480 %}"
        alt="{{ mobile_img.alt }}"
      {% else %}
        src="{% render 'imgix', src: desktop_master, w: 960 %}"
        alt="{{ desktop_img.alt }}"
      {% endif %}
      loading="lazy"
      width="{{ dim_w }}"
      height="{{ dim_h }}"
      sizes="{{ promo_sizes }}"
      class="block w-full h-auto object-cover {{ promo_section_image_classes }}"
    >
  </picture>
  {% comment %}theme-check-enable RemoteAsset {% endcomment %}
{% endif %}

{%- if promo_section_url != blank -%}
  </a>
{%- endif -%}

<div class="absolute z-10 {{ promo_section_content_classes }}">
  {{ promo_section_content }}
</div>