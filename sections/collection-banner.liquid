{%- liquid
  if collection.metafields.custom.banner_image_mobile != nil or collection.metafields.custom.banner_image_desktop != nil
    assign custom_banner = true
  else
    assign custom_banner = false
  endif
-%}
<div class="collection-hero {% if custom_banner %}pb-4{% else %}py-4{% endif %}">
  <div class="container px-0 xs:px-6">
    {%- if custom_banner -%}
      {%- liquid
        assign fallback_banner_image = collection.metafields.custom.banner_image_mobile
        if fallback_banner_image == blank
          assign fallback_banner_image = collection.metafields.custom.banner_image_desktop
        endif
        assign mobile_image_master = collection.metafields.custom.banner_image_mobile | image_url
        assign desktop_image_master = collection.metafields.custom.banner_image_desktop | image_url
        assign fallback_banner_image_master = fallback_banner_image | image_url
      -%}
      {% comment %}theme-check-disable ImgLazyLoading, RemoteAsset {% endcomment %}
      <picture>
        {%- if collection.metafields.custom.banner_image_mobile != blank -%}
          <source
            srcset="
              {% render 'imgix', src: mobile_image_master, w: 320 %} 320w,
              {% render 'imgix', src: mobile_image_master, w: 480 %} 480w,
              {% render 'imgix', src: mobile_image_master, w: 640 %} 640w,
              {% render 'imgix', src: mobile_image_master, w: 750 %} 750w
            "
            sizes="100vw"
            media="(max-width: 639px)"
          >
        {%- endif %}
        {%- if collection.metafields.custom.banner_image_desktop != blank -%}
          <source
            srcset="
              {% render 'imgix', src: desktop_image_master, w: 640 %} 640w,
              {% render 'imgix', src: desktop_image_master, w: 960 %} 960w,
              {% render 'imgix', src: desktop_image_master, w: 1200 %} 1200w,
              {% render 'imgix', src: desktop_image_master, w: 1600 %} 1600w
            "
            sizes="100vw"
            media="(min-width: 640px) and (max-width: 1023px)"
          >
          <source
            srcset="
              {% render 'imgix', src: desktop_image_master, w: 960 %} 960w,
              {% render 'imgix', src: desktop_image_master, w: 1200 %} 1200w,
              {% render 'imgix', src: desktop_image_master, w: 1600 %} 1600w,
              {% render 'imgix', src: desktop_image_master, w: 2000 %} 2000w,
              {% render 'imgix', src: desktop_image_master, w: 2400 %} 2400w
            "
            sizes="100vw"
            media="(min-width: 1024px)"
          >
        {%- endif %}
        <img
          src="{% render 'imgix', src: fallback_banner_image_master, w: 480 %}"
          srcset="
            {% render 'imgix', src: fallback_banner_image_master, w: 320 %} 320w,
            {% render 'imgix', src: fallback_banner_image_master, w: 480 %} 480w,
            {% render 'imgix', src: fallback_banner_image_master, w: 640 %} 640w,
            {% render 'imgix', src: fallback_banner_image_master, w: 750 %} 750w
          "
          sizes="100vw"
          alt="{{ fallback_banner_image.alt }}"
          width="{{ fallback_banner_image.width }}"
          height="{{ fallback_banner_image.height }}"
          class="block w-full mb-6"
        >
      </picture>
      {% comment %}theme-check-enable ImgLazyLoading, RemoteAsset {% endcomment %}
    {%- endif -%}
  </div>
  <div class="container">
    <div class="lg:py-4">
      <h1 class="font-serif text-4xl tracking-tight mr-2 xl:text-5xl">
        {%- if collection.metafields.custom.custom_title != blank -%}
          {{- collection.metafields.custom.custom_title | escape -}}
        {%- else -%}
          {{- collection.title | escape -}}
        {%- endif -%}
      </h1>

      {%- if section.settings.show_collection_description -%}
        <p class="tracking-wide lg:text-lg xl:text-xl">{{ collection.description }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.show_collection_image and collection.image -%}
      <div class="collection-hero__image-container media">
        <img
          srcset="{%- if collection.image.width >= 165 -%}{{ collection.image | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if collection.image.width >= 360 -%}{{ collection.image | image_url: width: 360 }} 360w,{%- endif -%}
            {%- if collection.image.width >= 535 -%}{{ collection.image | image_url: width: 535 }} 535w,{%- endif -%}
            {%- if collection.image.width >= 750 -%}{{ collection.image | image_url: width: 750 }} 750w,{%- endif -%}
            {%- if collection.image.width >= 1070 -%}{{ collection.image | image_url: width: 1070 }} 1070w,{%- endif -%}
            {%- if collection.image.width >= 1500 -%}{{ collection.image | image_url: width: 1500 }} 1500w,{%- endif -%}
            {{ collection.image | image_url: width: 5760 }} {{ collection.image.width }}w"
          src="{{ collection.image | image_url: width: 750 }}"
          sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc(50vw - 130px), calc(50vw - 55px)"
          alt="{{ collection.title | escape }}"
          loading="lazy"
          width="{{ collection.image.width }}"
          height="{{ collection.image.height }}"
        >
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": false,
      "label": "t:sections.main-collection-banner.settings.show_collection_image.label",
      "info": "t:sections.main-collection-banner.settings.show_collection_image.info"
    }
  ]
}
{% endschema %}
