{%- assign ugc_video_entries = product.metafields.custom.ugc_video.value -%}
{%- if ugc_video_entries != blank -%}
<div class="product-ugc-videos container mb-6 lg:mb-12 {{ section.settings.section_classes }}">
  <div class="bg-white rounded-xl p-6 lg:p-10">
    <div class="text-center mb-5">
      {% if section.settings.header != blank %}<h3 class="relative text-3xl md:text-4xl tracking-tight font-serif leading-none mb-2">{{ section.settings.header }}</h3>{% endif %}
      {% if section.settings.subheader != blank %}<p class="relative text-sm leading-tight tracking-wide">{{ section.settings.subheader }}</p>{% endif %}
    </div>
    <horizontal-scroll-box class="relative">
      <div class="scroll-box flex gap-3 snap-x overflow-x-auto pb-3">
        {%- for ugc_video in ugc_video_entries -%}
          {%- assign video = ugc_video.video.value -%}
          {%- if video == blank -%}
            {%- continue -%}
          {%- endif -%}
          {%- assign creator_link = ugc_video.creator_url.value -%}
          {%- assign creator_name = creator_link.text -%}
          {%- assign creator_url = creator_link.url -%}
          {%- assign poster_master = video.preview_image | image_url -%}
          <div class="w-64 shrink-0">
            <div class="relative" style="cursor: default;">
              <video
                poster="{% render 'imgix', src: poster_master, w: 640 %}"
                controls
                playsinline
                preload="none"
                class="block w-full rounded-lg"
                onplay="this.nextElementSibling.classList.add('hidden')"
                onpause="this.nextElementSibling.classList.remove('hidden')"
                onended="this.nextElementSibling.classList.remove('hidden')"
              >
                {% comment %} theme-check-disable RemoteAsset {% endcomment %}
                {% for source in video.sources %}
                  <source src="{{ source.url }}" type="{{ source.mime_type }}">
                {% endfor %}
                Your browser does not support the video tag.
                {% comment %} theme-check-enable RemoteAsset {% endcomment %}
              </video>
              <button
                type="button"
                class="flex absolute top-1/2 left-1/2 z-10 justify-center items-center w-20 h-20 rounded-full scale-100 -translate-x-1/2 -translate-y-1/2 cursor-pointer deferred-media__poster-button bg-white/50 motion-safe:transition-transform hover:scale-110"
                style="clip-path: circle(50%);"
                aria-label="Play video"
                onclick="this.previousElementSibling.play()"
              >
                {%- render 'icon-play', classes: 'w-8 h-8 text-white -mr-1 ml-1', aria_hidden: true -%}
              </button>
            </div>
            {%- if creator_name != blank and creator_url != blank -%}
              <a
                href="{{ creator_url | escape }}"
                class="mt-2 block text-center text-sm leading-tight text-seaweed-700 underline underline-offset-2 motion-safe:transition-colors hover:text-seaweed-500"
                target="_blank"
                rel="noopener noreferrer"
              >
                {{- creator_name | escape -}}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      <nav>
        <button class="next nav-hide absolute top-1/2 -right-3 bottom-3 z-10 bg-white w-8 h-8 -mt-7 rounded-full shadow-md shadow-seaweed-700/10 flex items-center justify-center motion-safe:transition-opacity" aria-label="Next">
          {% render 'icon-arrow', variant: 'short', classes: 'w-6 h-6', stroke_width: 1.5 %}
        </button>
        <button class="prev nav-hide absolute top-1/2 -left-7 bottom-3 z-10 bg-white w-8 h-8 -mt-7 rounded-full shadow-md shadow-seaweed-700/10 flex items-center justify-center motion-safe:transition-opacity" aria-label="Previous">
          {% render 'icon-arrow', variant: 'short', classes: 'w-6 h-6 rotate-180', stroke_width: 1.5 %}
        </button>
      </nav>
    </horizontal-scroll-box>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "UGC Videos",
  "tag": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "section_classes",
      "label": "Section classes"
    },
    {
      "type": "text",
      "id": "header",
      "label": "Header",
      "default": "What our customers are saying"
    },
    {
      "type": "text",
      "id": "subheader",
      "label": "Subheader",
      "default": "Check out these reviews from real OSEA customers"
    }
  ],
  "presets": [
    {
      "name": "UGC Videos"
    }
  ]
}
{% endschema %}
